# Claude API
ANTHROPIC_API_KEY=

# Parametri edizione
# EDIZIONE_NUMERO: numero progressivo dell'edizione (es. 1, 2, 3...).
#   Usato da --publish per filtrare solo le notizie con colonna J = questo numero.
#   OBBLIGATORIO per --publish. Non impostare un default — deve essere esplicito.
EDIZIONE_NUMERO=
EDIZIONE_MESE=Maggio
EDIZIONE_ANNO=2026

# FINESTRA_GIORNI non è più usata per calcolare la finestra di scraping
# (lo scraping usa sempre la settimana ISO corrente: da lunedì a domenica).
# Mantenuta per compatibilità futura.
FINESTRA_GIORNI=7

# Upload futuro (default: none)
UPLOAD_DESTINATION=none